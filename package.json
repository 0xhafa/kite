    "@types/node": "24.10.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "4.3.2",
