# Banco libSQL local. Em produção, use uma URL Turso e mantenha o token somente no servidor.
DATABASE_URL=file:.data/kite.db
# DATABASE_AUTH_TOKEN=

# Segredos devem existir somente no servidor e nunca usar o prefixo NEXT_PUBLIC_.

# O mock determinístico é o padrão para desenvolvimento e testes offline.
AI_PROVIDER=mock

# Para um endpoint compatível com Chat Completions, use AI_PROVIDER=http e
# configure todos os campos abaixo somente no ambiente do servidor.
# AI_PROVIDER=http
# AI_BASE_URL=https://api.openai.com/v1/
# AI_API_KEY=
# AI_MODEL=
# AI_TIMEOUT_MS=30000
