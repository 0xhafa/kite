# Banco libSQL local. Em produção, use uma URL Turso e mantenha o token somente no servidor.
DATABASE_URL=file:.data/kite.db
# DATABASE_AUTH_TOKEN=

# Segredos devem existir somente no servidor e nunca usar o prefixo NEXT_PUBLIC_.

# O mock determinístico é o padrão para desenvolvimento e testes offline.
AI_PROVIDER=mock

# Para usar APIs reais compatíveis com Chat Completions, use AI_PROVIDER=http.
# Adicione somente as chaves dos provedores que deseja disponibilizar. O provedor,
# o modelo e o esforço são selecionados pelo usuário no painel de configurações.
# AI_PROVIDER=http
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=

# Os endpoints oficiais já são os padrões. Sobrescreva apenas para proxy/gateway.
# OPENAI_BASE_URL=https://api.openai.com/v1/
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# GROQ_BASE_URL=https://api.groq.com/openai/v1/
# Aguarda até 5 minutos pela resposta completa do provedor.
# AI_TIMEOUT_MS=300000
